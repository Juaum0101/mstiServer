    <script>
        // Data Models
        let playerName = '';
        const MAX_DECK = 20;
        const MAX_MOT = 60;
        let selectedCards = new Set();

        const cards = [
            { id: 'c1', title: 'Cerebral Strike', mot: 2, desc: 'A focused physical attack bypassing standard armor metrics.', tags: ['Melee', 'Tactical'], type: 'normal' },
            { id: 'c2', title: 'Aegis Protocol', mot: 3, desc: 'Deploy a temporary kinetic barrier to absorb incoming force.', tags: ['Defense', 'Tech'], type: 'normal' },
            { id: 'c3', title: 'Synaptic Overload', mot: 5, desc: 'High-risk maneuver dealing area damage; chance to self-stun.', tags: ['AoE', 'Psionic'], tagColors: ['text-error', 'text-on-surface-variant'], type: 'normal' },
            { id: 'c4', title: 'Phantom Step', mot: 1, desc: 'Evasive repositioning sub-routine. Increases dodge matrix.', tags: ['Movement', 'Utility'], type: 'normal' },
            { id: 'c5', title: 'Alpha Mutation', mot: 15, desc: 'Drastic cellular restructuring. Grants immense strength but degrades vital stability.', tags: ['Mutation', 'Passive'], type: 'mutation', effect: '-11 Max HP' },
            { id: 'c6', title: 'Beta Mutation', mot: 10, desc: 'Adaptive neural pathways. Enhances reflex speed at the cost of endurance.', tags: ['Mutation', 'Passive'], type: 'mutation', effect: '-7 Max HP' }
        ];

        // Elements
        const nameInput = document.getElementById('player_name');
        const viewToggleBtns = document.querySelectorAll('#view-toggle button');
        const viewArchetypes = document.getElementById('view-archetypes');
        const viewCustom = document.getElementById('view-custom');
        const shardGrid = document.getElementById('shard-grid');
        const deckCount = document.getElementById('deck-count');
        const deckBar = document.getElementById('deck-bar');
        const motCount = document.getElementById('mot-count');
        const motBar = document.getElementById('mot-bar');
        const motBarContainer = document.getElementById('mot-bar-container');
        const mutationPenalty = document.getElementById('mutation-penalty');
        const mutationNameEl = document.getElementById('mutation-name');
        const mutationEffectEl = document.getElementById('mutation-effect');
        const confirmBtn = document.getElementById('confirm-btn');
        const confirmIcon = document.getElementById('confirm-icon');

        // Logic
        nameInput.addEventListener('input', (e) => {
            playerName = e.target.value;
            updateConfirmButton();
        });

        viewToggleBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetView = e.target.getAttribute('data-view');

                viewToggleBtns.forEach(b => {
                    b.classList.remove('text-primary', 'border-b-2', 'border-primary');
                    b.classList.add('text-on-surface-variant');
                });
                e.target.classList.remove('text-on-surface-variant');
                e.target.classList.add('text-primary', 'border-b-2', 'border-primary');

                if (targetView === 'archetypes') {
                    viewArchetypes.classList.remove('hidden');
                    viewCustom.classList.add('hidden');
                } else {
                    viewArchetypes.classList.add('hidden');
                    viewCustom.classList.remove('hidden');
                }
            });
        });

        function renderCards() {
            shardGrid.innerHTML = '';
            cards.forEach(card => {
                const isSelected = selectedCards.has(card.id);

                const cardEl = document.createElement('div');
                cardEl.className = `border p-4 clip-corner-cut relative group cursor-pointer transition-colors ${isSelected ? 'border-primary bg-primary/5' : 'border-outline-variant hover:border-primary/50'}`;
                cardEl.onclick = () => toggleCard(card.id);

                let tagsHtml = '';
                card.tags.forEach((tag, idx) => {
                    const colorClass = (card.tagColors && card.tagColors[idx]) ? card.tagColors[idx] : (card.type === 'mutation' ? 'text-error' : 'text-on-surface-variant');
                    tagsHtml += `<span class="px-2 py-0.5 border border-outline-variant/50 text-[10px] font-label-sm ${colorClass} uppercase">${tag}</span>`;
                });

                const diamond = isSelected ? `<div class="absolute top-2 right-2 w-2 h-2 bg-primary clip-diamond shadow-[0_0_8px_rgba(242,202,80,0.8)]"></div>` : '';

                cardEl.innerHTML = `
                    ${diamond}
                    <div class="flex justify-between items-start mb-2">
                        <h4 class="font-title-md text-title-md ${isSelected ? 'text-primary' : 'text-on-surface'}">${card.title}</h4>
                        <span class="font-label-sm text-label-sm text-outline-variant">${card.mot} MoT</span>
                    </div>
                    <p class="font-body-md text-body-md text-on-surface-variant text-sm line-clamp-2 mb-3">${card.desc}</p>
                    <div class="flex gap-2">
                        ${tagsHtml}
                    </div>
                `;

                // Hover effect for corner cut icon logic from original snippet
                cardEl.addEventListener('mouseenter', () => {
                    if (!isSelected) cardEl.classList.add('bg-surface-container-high');
                });
                cardEl.addEventListener('mouseleave', () => {
                    if (!isSelected) cardEl.classList.remove('bg-surface-container-high');
                });

                shardGrid.appendChild(cardEl);
            });
        }

        function toggleCard(cardId) {
            if (selectedCards.has(cardId)) {
                selectedCards.delete(cardId);
            } else {
                if (selectedCards.size < MAX_DECK) {
                    selectedCards.add(cardId);
                }
            }
            updateTelemetry();
            renderCards();
        }

        function updateTelemetry() {
            const count = selectedCards.size;
            let totalMot = 0;
            let activeMutation = null;

            selectedCards.forEach(id => {
                const card = cards.find(c => c.id === id);
                if (card) {
                    totalMot += card.mot;
                    if (card.type === 'mutation') {
                        activeMutation = card;
                    }
                }
            });

            // Deck Update
            deckCount.textContent = `${count}/${MAX_DECK}`;
            deckBar.style.width = `${(count / MAX_DECK) * 100}%`;

            // MoT Update
            motCount.textContent = `${totalMot}/${MAX_MOT}`;
            const motPercentage = Math.min((totalMot / MAX_MOT) * 100, 100);
            motBar.style.width = `${motPercentage}%`;

            if (totalMot > MAX_MOT) {
                motCount.classList.remove('text-tertiary');
                motCount.classList.add('text-error');
                motBar.classList.remove('bg-tertiary');
                motBar.classList.add('bg-error');
                motBarContainer.classList.remove('bg-tertiary/10');
                motBarContainer.classList.add('bg-error/10');
            } else {
                motCount.classList.add('text-tertiary');
                motCount.classList.remove('text-error');
                motBar.classList.add('bg-tertiary');
                motBar.classList.remove('bg-error');
                motBarContainer.classList.add('bg-tertiary/10');
                motBarContainer.classList.remove('bg-error/10');
            }

            // Mutation Penalty
            if (activeMutation) {
                mutationPenalty.classList.remove('hidden');
                mutationNameEl.textContent = activeMutation.title;
                mutationEffectEl.textContent = activeMutation.effect;
            } else {
                mutationPenalty.classList.add('hidden');
            }

            updateConfirmButton(totalMot);
        }

        function updateConfirmButton(totalMot = 0) {
            if (selectedCards.size === 0) {
                selectedCards.forEach(id => {
                    const card = cards.find(c => c.id === id);
                    if (card) totalMot += card.mot;
                });
            }

            const isValidName = playerName.trim().length > 0;
            const isValidMot = totalMot <= MAX_MOT;
            const hasCards = selectedCards.size > 0;

            if (isValidName && isValidMot && hasCards) {
                confirmBtn.disabled = false;
                confirmBtn.classList.remove('bg-surface-container-high', 'text-outline-variant', 'cursor-not-allowed');
                confirmBtn.classList.add('bg-primary/10', 'border-primary', 'text-primary', 'hover:bg-primary/20', 'cursor-pointer');
                confirmIcon.textContent = 'check';
                confirmIcon.parentElement.classList.remove('clip-corner-cut-gold');
                confirmIcon.parentElement.classList.add('clip-corner-cut');
            } else {
                confirmBtn.disabled = true;
                confirmBtn.classList.add('bg-surface-container-high', 'text-outline-variant', 'cursor-not-allowed');
                confirmBtn.classList.remove('bg-primary/10', 'border-primary', 'text-primary', 'hover:bg-primary/20', 'cursor-pointer');
                confirmIcon.textContent = 'lock';
                confirmIcon.parentElement.classList.add('clip-corner-cut-gold');
                confirmIcon.parentElement.classList.remove('clip-corner-cut');
            }
        }

        // Init
        // Pre-select some based on initial HTML visual state
        selectedCards.add('c1'); // Cerebral Strike
        selectedCards.add('c4'); // Phantom Step
        updateTelemetry();
        renderCards();

    </script>
</body>

</html>

