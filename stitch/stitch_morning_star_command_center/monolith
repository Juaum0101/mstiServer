    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Match Config State
            const matchConfig = {
                mutationsAllowed: true,
                marksActive: true,
                techniquesEnabled: true,
                classVisibility: false,
                namesVisible: true,
                fog_range: 4,
                newbieMode: false,
                perTurnLimit: 60,
                matchTimer: 15
            };

            // Bind Checkboxes
            const binds = {
                'toggle-mutations': 'mutationsAllowed',
                'toggle-marks': 'marksActive',
                'toggle-techniques': 'techniquesEnabled',
                'toggle-class-visibility': 'classVisibility',
                'toggle-names-visible': 'namesVisible',
                'toggle-newbie': 'newbieMode'
            };

            for (const [id, key] of Object.entries(binds)) {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener('change', (e) => {
                        matchConfig[key] = e.target.checked;
                        console.log(`Config updated: ${key} = ${matchConfig[key]}`);
                    });
                }
            }

            // Bind Slider
            const fowSlider = document.getElementById('slider-fow');
            const fowValue = document.getElementById('fow-value');
            if (fowSlider && fowValue) {
                fowSlider.addEventListener('input', (e) => {
                    const val = parseInt(e.target.value, 10);
                    fowValue.innerText = val;
                    matchConfig.fog_range = val;
                    console.log(`Config updated: fog_range = ${matchConfig.fog_range}`);
                });
            }

            // Bind Inputs
            const turnLimit = document.getElementById('input-turn-limit');
            if (turnLimit) {
                turnLimit.addEventListener('change', (e) => {
                    matchConfig.perTurnLimit = parseInt(e.target.value, 10);
                });
            }
            const matchTimer = document.getElementById('input-match-timer');
            if (matchTimer) {
                matchTimer.addEventListener('change', (e) => {
                    matchConfig.matchTimer = parseInt(e.target.value, 10);
                });
            }

            // Mock MQTT / Lobby Sync
            const rosterEl = document.getElementById('lobby-roster');
            const countEl = document.getElementById('roster-count');

            const mockPlayers = [
                { id: 'p1', name: 'Aurelius', status: 'Ready' },
                { id: 'p2', name: 'Vanguard_01', status: 'Modifying' },
                { id: 'p3', name: 'GhostWalker', status: 'Spectator' }
            ];

            function renderRoster(players) {
                if (!rosterEl) return;
                rosterEl.innerHTML = '';
                countEl.innerText = `${players.length} Players`;

                players.forEach(p => {
                    let icon = 'schedule';
                    let color = 'text-on-surface-variant';

                    if (p.status === 'Ready') {
                        icon = 'check_circle';
                        color = 'text-primary';
                    } else if (p.status === 'Modifying') {
                        icon = 'build';
                        color = 'text-tertiary';
                    } else if (p.status === 'Spectator') {
                        icon = 'visibility';
                        color = 'text-outline';
                    }

                    const li = document.createElement('li');
                    li.className = 'flex items-center justify-between bg-surface-variant/50 p-2 border border-outline-variant rounded';
                    li.innerHTML = `
