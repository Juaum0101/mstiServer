    <script>
        function transitionToLogin() {
            const selectionState = document.getElementById('state-selection');
            const loginState = document.getElementById('state-login');
            const inputField = document.getElementById('player-name-input');

            // Fade out selection
            selectionState.style.opacity = '0';
            selectionState.style.transform = 'translateY(-10px)';

            setTimeout(() => {
                selectionState.classList.add('hidden-state');

                // Prepare login state
                loginState.classList.remove('hidden-state');
                // Force reflow
                void loginState.offsetWidth;

                // Fade in login
                loginState.style.opacity = '1';
                loginState.style.transform = 'translateY(0)';

                // Focus input after transition
                setTimeout(() => {
                    inputField.focus();
                }, 300);

            }, 400); // Wait for fade out
        }

        function transitionToSelection() {
            const selectionState = document.getElementById('state-selection');
            const loginState = document.getElementById('state-login');

            // Fade out login
            loginState.style.opacity = '0';
            loginState.style.transform = 'translateY(10px)';

            setTimeout(() => {
                loginState.classList.add('hidden-state');

                // Prepare selection state
                selectionState.classList.remove('hidden-state');
                // Force reflow
                void selectionState.offsetWidth;

                // Fade in selection
                selectionState.style.opacity = '1';
                selectionState.style.transform = 'translateY(0)';

            }, 400);
        }
    </script>
