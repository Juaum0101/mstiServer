    <script>
        // 1. State Management
        let localTurnState = {
            move_dir: null,
            action_id: null,
            target_sector: null,
            sp_influx_value: 0,
            mitigation_spent: 0,
            cost: 0
        };

        let currentStamina = 5;
        let maxStamina = 10;

        // 2. MQTT Integration
        let mqttClient;
        function initMQTT() {
            const clientId = "msk_client_" + Math.random().toString(16).substr(2, 8);
            const brokerUrl = "broker.hivemq.com"; // Placeholder broker URL
            const port = 8000;

            mqttClient = new Paho.MQTT.Client(brokerUrl, port, clientId);

            mqttClient.onConnectionLost = function (responseObject) {
                if (responseObject.errorCode !== 0) {
                    console.log("MQTT Connection Lost: " + responseObject.errorMessage);
                }
            };

            mqttClient.connect({
                onSuccess: function () {
                    console.log("MQTT Connected");
                },
                useSSL: true
            });
        }

        // 3. Tactical Action Grid & 5. Vitals Constraints
        function updateVitals() {
            const actionButtons = document.querySelectorAll('.action-btn');
            const spBar = document.getElementById('sp-bar-fill');
            const container = document.getElementById('vitals-container');

            actionButtons.forEach(btn => {
                const cost = parseInt(btn.dataset.cost || 0);
                if (cost > currentStamina) {
                    btn.classList.add('disabled-action');
                } else {
                    btn.classList.remove('disabled-action');
                }
            });

            const predictedStamina = currentStamina - localTurnState.cost;
            if (predictedStamina < 0) {
                container.classList.add('animate-pulse', 'border-red-600');
                container.classList.remove('border-outline-variant');
            } else {
                container.classList.remove('animate-pulse', 'border-red-600');
                container.classList.add('border-outline-variant');
            }

            const spPercentage = Math.max(0, (predictedStamina / maxStamina) * 100);
            spBar.style.width = `${spPercentage}%`;
        }

        function selectAction(actionId, cost) {
            localTurnState.action_id = actionId;
            localTurnState.cost = cost;
            updateVitals();
            console.log("Selected Action:", localTurnState);

            // Handle Attack Sub-menu toggle
            if (actionId === 'attack') {
                document.getElementById('attack-submenu').classList.toggle('hidden');
            } else {
                document.getElementById('attack-submenu').classList.add('hidden');
            }
        }

        function selectSubAction(subActionId, cost) {
            localTurnState.action_id = 'attack_' + subActionId;
            localTurnState.cost = cost;
            updateVitals();
            document.getElementById('attack-submenu').classList.add('hidden');
        }

        // 4. Techniques Drawer
        function toggleTechnique(id) {
            const desc = document.getElementById(`desc-${id}`);
            desc.classList.toggle('hidden');
        }

        function updateInflux(id, change) {
            const input = document.getElementById(`influx-${id}`);
            let val = parseInt(input.value) + change;
            if (val < 0) val = 0;
            input.value = val;
            localTurnState.sp_influx_value = val;
            localTurnState.cost = val; // Assuming cost scales with influx
            updateVitals();
        }

        // 6. Mitigation Engine
        function showMitigation() {
            document.getElementById('mitigation-overlay').classList.remove('hidden');
        }

        function updateMitigationSlider(val) {
            document.getElementById('mitigation-val').innerText = val;
            localTurnState.mitigation_spent = parseInt(val);
        }

        function closeMitigation() {
            document.getElementById('mitigation-overlay').classList.add('hidden');
        }

        // 7. JSON Assembler
        function commitTurn() {
            if (!mqttClient || !mqttClient.isConnected()) {
                console.warn("MQTT not connected. Cannot commit turn.");
                return;
            }

            const payload = JSON.stringify(localTurnState);
            const message = new Paho.MQTT.Message(payload);
            message.destinationName = "msk/turn/submit";
            mqttClient.send(message);
            console.log("Turn Committed:", payload);

            // Reset state
            localTurnState = {
                move_dir: null,
                action_id: null,
                target_sector: null,
                sp_influx_value: 0,
                mitigation_spent: 0,
                cost: 0
            };
            updateVitals();
        }

        window.onload = function () {
            initMQTT();
            updateVitals();
        };
    </script>
