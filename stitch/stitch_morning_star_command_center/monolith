                    </div>
                `;
                    rosterEl.appendChild(li);
                });
            }

            // Simulate incoming MQTT message after 1s
            setTimeout(() => {
                console.log("MQTT [RCV] /lobby/players");
                renderRoster(mockPlayers);
            }, 1000);

            // Vote to start
            const startBtn = document.getElementById('btn-start-match');
            const sysStatus = document.getElementById('system-status');
            if (startBtn) {
                startBtn.addEventListener('click', () => {
                    console.log("MQTT [PUB] /lobby/vote", matchConfig);
                    startBtn.innerHTML = `
                    <span class="material-symbols-outlined animate-spin">refresh</span>
                    Voting...
                `;
                    startBtn.disabled = true;
                    startBtn.classList.add('opacity-50');

                    // Simulate server broadcast command
                    setTimeout(() => {
                        console.log("MQTT [RCV] /lobby/start");
                        if (sysStatus) sysStatus.innerText = "INITIALIZING MATCH";
                        startBtn.innerHTML = `
                        <span class="material-symbols-outlined">rocket_launch</span>
                        Match Starting
                    `;
                        startBtn.classList.remove('opacity-50');
                        startBtn.classList.add('bg-tertiary', 'text-on-tertiary');
                    }, 2000);
                });
            }
        });
    </script>


